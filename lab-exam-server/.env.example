# Application
APP_NAME="Lab Exam Server"
APP_VERSION="1.0.0"
DEBUG=true

# Security — Admin API key (send as X-Admin-Key header)
ADMIN_SECRET_KEY=change-this-before-exam

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./data/lab_exam.db

# Paths
SEED_DATA_DIR=./data/seed

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/server.log
